# === LLM Provider ===
# openai | openrouter | custom
LLM_PROVIDER=custom
MODEL_NAME=your-model-name

# openai (official or Azure OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# openrouter (legacy default)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Pin routing to tool-capable providers only. OpenRouter otherwise load-balances
# onto providers that don't support `tools` (e.g. Novita, AtlasCloud), which
# return MiniMax tool calls as unparsed XML and break agent mode. Comma-separated
# provider slugs; empty to disable pinning.
OPENROUTER_PROVIDERS=minimax,together,parasail

# === Rate limiting (proactive throttle, no retries) ===
# Pace every model call to stay under the provider limit instead of hitting 429.
# requests_per_second: 0.5 = one call every 2s; lower it if you still see 429s.
LLM_REQUESTS_PER_SECOND=0.5
LLM_MAX_BURST=1
# Client-side retries on 429/5xx. 0 = rely solely on the throttle above.
LLM_MAX_RETRIES=0

# custom — corporate hosted OpenAI-compatible endpoint
CUSTOM_LLM_BASE_URL=https://llm.mycorp.local/v1
CUSTOM_LLM_API_KEY=

# === Embeddings (used only by the search_vector RAG tool) ===
# openai | gigachat
EMBED_PROVIDER=openai

# openai-compatible embeddings (default)
EMBED_MODEL=mistralai/mistral-embed-2312
EMBED_API_BASE=https://openrouter.ai/api/v1
EMBED_API_KEY=

# gigachat embeddings (Sber) — set EMBED_PROVIDER=gigachat to enable
GIGACHAT_CREDENTIALS=                 # base64 of "client_id:client_secret" (from the GigaChat cabinet)
# or, instead of the line above:
# GIGACHAT_CLIENT_ID=
# GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS      # GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_EMBED_MODEL=Embeddings       # or EmbeddingsGigaR
GIGACHAT_CA_BUNDLE=/workspace/certs/russian_trusted_root_ca.pem   # Минцифры root CA (файл кладётся в ./certs, см. certs/README.md)
# GIGACHAT_VERIFY_SSL=false           # insecure fallback if you have no CA bundle
# On-prem GigaChat: override the endpoints (and/or supply a static token)
# GIGACHAT_BASE_URL=https://gigachat.mycorp.local/api/v1
# GIGACHAT_OAUTH_URL=https://gigachat.mycorp.local:9443/api/v2/oauth
# GIGACHAT_ACCESS_TOKEN=             # skips OAuth entirely

# === Tracing ===
# langsmith | langfuse | none. Closed network: keep "none" — cloud tracing
# would try to send run data (incl. document text) to LangSmith/LangFuse.
TRACING_PROVIDER=none

# langsmith (auto via LANGCHAIN_* env vars)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=deep-agent

# langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PROJECT=deep-agent

# === Network guard (in-process egress allowlist, optional) ===
# off (default) = no-op; the network perimeter handles isolation.
# strict = refuse ANY outbound connection except the endpoints configured above
# (active LLM provider + embeddings provider) and loopback. Library telemetry
# and accidental defaults (api.openai.com, openrouter.ai, huggingface.co,
# langfuse) fail with BlockedEgressError BEFORE any byte is sent.
NETWORK_GUARD=off
# Extra hosts to allow in strict mode (comma-separated), e.g. a corporate proxy:
# NETWORK_EXTRA_ALLOWED_HOSTS=proxy.corp.local

# === Extraction pipeline ===
# agent (default) | deterministic
#   agent         = full deepagents orchestrator + field subagents + tools.
#                   LLM-driven; needs a strong native tool-calling model
#                   (weak models like minimax-m3 tend to return empty results).
#   deterministic = code-driven per-field retrieve+extract. Stable fallback on
#                   weak models; no subagent orchestration required.
EXTRACTION_MODE=agent
# parallel field extractions in deterministic mode (independent LLM calls)
EXTRACTION_WORKERS=4
# retrieval: hybrid BM25+vector fused with RRF. Falls back to BM25-only if
# embeddings are unreachable (offline / no key) — safe in a closed network.
EXTRACTION_HYBRID=1
# 0..1 RRF weight on BM25 (lexical). Higher = lean on exact clause numbers/terms.
EXTRACTION_BM25_WEIGHT=0.7
# how many chunks of context per field (docs are small → can be generous).
# 12 favors recall so clauses spread across several organ-competence sections
# (Общее собрание + Наблюдательный совет/Совет директоров) are all captured.
EXTRACTION_TOP_K=12
# chunking: hierarchical (structure-aware, default) | fixed (~1500-char windows)
EXTRACTION_CHUNKING=hierarchical

# Persistent, content-addressed cache for document-derived artifacts (docling
# markdown, embeddings), keyed by file hash. Lives OUTSIDE the per-run /scratch
# (wiped each run), so docling + embedding run once per unique file across runs.
# Defaults to <WORK_ROOT>/../cache. Point at a mounted volume to persist between
# containers. Delete the dir to force a rebuild.
# CACHE_ROOT=/workspace/work/cache

# === Cost Controls ===
MAX_SUBAGENTS_PER_RUN=15
MAX_TOKENS_PER_RUN=200000
